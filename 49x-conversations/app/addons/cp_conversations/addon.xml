    <queries>
        <item for="install" >
            CREATE TABLE `?:cp_conversations` (
                `conversation_id` INT(11) UNSIGNED NOT NULL AUTO_INCREMENT,
                `subject` varchar(255) NOT NULL DEFAULT '',
                `timestamp` int(11) UNSIGNED NOT NULL DEFAULT '0',
                `author_id` int(11) UNSIGNED NOT NULL DEFAULT '0',
                `order_id` int(11) UNSIGNED NOT NULL DEFAULT '0',
                PRIMARY KEY (`conversation_id`)
            ) ENGINE=MyISAM DEFAULT CHARSET=utf8;
        </item>
        <item for="uninstall">
            DROP TABLE `?:cp_conversations`;
        </item>

        <item for="install">
            CREATE TABLE `?:cp_messages` (
                `message_id` INT(11) UNSIGNED NOT NULL AUTO_INCREMENT,
                `conversation_id` INT(11) UNSIGNED NOT NULL DEFAULT '0',
                `user_id` INT(11) UNSIGNED NOT NULL DEFAULT '0',
                `message` MEDIUMTEXT NOT NULL DEFAULT '',
                `timestamp` int(11) UNSIGNED NOT NULL DEFAULT '0',
                PRIMARY KEY (`message_id`)
            ) ENGINE=MyISAM DEFAULT CHARSET=utf8;
        </item>
        <item for="uninstall">
            DROP TABLE `?:cp_messages`;
        </item>

        <item for="install">
            CREATE TABLE `?:cp_conversation_users` (
                `conversation_id` INT(11) UNSIGNED NOT NULL DEFAULT 0,
                `recipient_id` INT(11) UNSIGNED NOT NULL DEFAULT 0,
                `read` VARCHAR(1) NOT NULL DEFAULT 'N',
                `spam` VARCHAR(1) NOT NULL DEFAULT 'N',
                `trash` VARCHAR(1) NOT NULL DEFAULT 'N',
                `archive` VARCHAR(1) NOT NULL DEFAULT 'N',
                `folder_id` INT(11) NOT NULL DEFAULT 0,
                `ekey` VARCHAR(255) NOT NULL DEFAULT '',
                 PRIMARY KEY (`conversation_id`, `recipient_id`)
            ) ENGINE=MyISAM DEFAULT CHARSET=utf8;
        </item>
        <item for="uninstall">
            DROP TABLE `?:cp_conversation_users`;
        </item>
        <item for="install">
            CREATE TABLE `?:cp_conversation_folders` (
                `folder_id` INT(11) UNSIGNED NOT NULL AUTO_INCREMENT,
                `folder` VARCHAR(255) NULL DEFAULT '',
                `user_id` INT(11) UNSIGNED NOT NULL DEFAULT '0',
                PRIMARY KEY (`folder_id`)
            ) ENGINE=MyISAM DEFAULT CHARSET=utf8;
        </item>
        <item for="uninstall">
            DROP TABLE `?:cp_conversation_folders`;
        </item>
        <item for="install">
            CREATE TABLE `?:cp_conversation_folder_links` (
                `folder_id` INT(11) UNSIGNED NOT NULL DEFAULT '0',
                `conversation_id` INT(11) UNSIGNED NOT NULL DEFAULT '0',
                `user_id` INT(11) UNSIGNED NOT NULL DEFAULT '0',
                PRIMARY KEY (`folder_id`, `conversation_id`, `user_id`)
            ) ENGINE=MyISAM DEFAULT CHARSET=utf8;
        </item>
        <item for="uninstall">
            DROP TABLE `?:cp_conversation_folder_links`;
        </item>
        <item for="install">
            CREATE TABLE `?:cp_conversation_message_files` (
                `item_id` INT(11) UNSIGNED NOT NULL AUTO_INCREMENT,
                `message_id` INT(11) UNSIGNED NOT NULL DEFAULT '0',
                `filename` VARCHAR(255) NOT NULL DEFAULT '',
                PRIMARY KEY (`item_id`)
            ) ENGINE=MyISAM DEFAULT CHARSET=utf8;
        </item>
        <item for="uninstall">
            DROP TABLE `?:cp_conversation_message_files`;
        </item>
        <item>ALTER TABLE ?:users ADD cp_for_conversation char(1) NOT NULL default 'N';</item>
        <item for="uninstall">ALTER TABLE ?:users DROP COLUMN cp_for_conversation;</item>
    </queries>
</addon>